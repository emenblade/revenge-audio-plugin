{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@vendetta": ["./vendetta-types/index.d.ts"],
      "@vendetta/*": ["./vendetta-types/*"]
    }
  },
  "include": ["plugins/**/*", "build.mjs"]
}
